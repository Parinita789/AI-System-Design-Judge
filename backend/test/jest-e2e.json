{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": "test/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "setupFiles": ["<rootDir>/test/setup.ts"],
  "globalSetup": "<rootDir>/test/global-setup.ts",
  "testTimeout": 30000,
  "maxWorkers": 1
}
