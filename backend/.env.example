NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://user:password@localhost:5432/ai_judge?schema=public

ANTHROPIC_API_KEY=
LLM_MODEL=claude-opus-4-7
LLM_MAX_TOKENS=4096

# Per-agent input-token warn threshold + plan.md truncation cap.
# Both auto-derive from the model's context window at call time
# (75% of context for the warn threshold, 5% for plan.md cap). Set
# these env vars only to override the derived value with a fixed
# number — useful when sweeping in the eval harness or when you
# want a tighter ceiling than the model's full context. Leave
# unset for normal operation.
#
# PLAN_AGENT_INPUT_TOKEN_WARN=150000
# BUILD_AGENT_INPUT_TOKEN_WARN=150000
# MENTOR_AGENT_INPUT_TOKEN_WARN=150000
# SIGNAL_MENTOR_AGENT_INPUT_TOKEN_WARN=150000
# PLAN_MD_TRUNCATION_CAP=50000

# Optional: local development via Ollama. When set, all LLM calls go to Ollama.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

RUBRIC_VERSION=v2.0
RUBRIC_DIR=./rubrics

CLAUDE_CODE_PROJECTS_DIR=/Users/parinita/.claude/projects
